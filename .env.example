# ==============================================================================
# Venta Max IA — Plantilla de Entorno (.env.example)
# ==============================================================================
# Copia este archivo a `.env` (`cp .env.example .env`) y personaliza los valores.
# Sin credenciales de IA el CRM opera al 100% (Kanban, contactos, chats manuales);
# solo el Agente autónomo y el Laboratorio requieren configurar al menos una API Key.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. NÚCLEO WEB Y AUTENTICACIÓN
# ------------------------------------------------------------------------------
APP_BASE_URL=http://localhost:3000
BETTER_AUTH_SECRET=genera_un_secreto_seguro_con_openssl_rand_base64_32
ALLOW_SIGNUP=true

# ------------------------------------------------------------------------------
# 2. BASE DE DATOS Y VECTOR STORE
# ------------------------------------------------------------------------------
# Por defecto apunta al contenedor PostgreSQL local levantado con `docker compose -f docker-compose.dev.yml up -d`
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/vocero
POSTGRES_PASSWORD=postgres

# ------------------------------------------------------------------------------
# 3. SEGURIDAD Y CIFRADO EN REPOSO (AES-256-GCM)
# ------------------------------------------------------------------------------
# Clave obligatoria (32 bytes en base64) para el cifrado en la base de datos.
# Puedes generarla en tu terminal con: `node -e "console.log(crypto.randomBytes(32).toString('base64'))"`
ENCRYPTION_KEY=

# ------------------------------------------------------------------------------
# 4. CANALES DE COMUNICACIÓN
# ------------------------------------------------------------------------------
# --- WhatsApp Cloud API ---
META_WEBHOOK_VERIFY_TOKEN=venta_max_ia_secret_verify_token_2026
META_APP_SECRET=

# --- Telegram Bot API ---
# Token de acceso del Bot proporcionado por @BotFather.
TELEGRAM_ADMIN_BOT_TOKEN=8941924456:AAHsEaE_...
# ID numérico de Telegram para alertas de sistema/admin y diagnóstico en vivo.
TELEGRAM_ADMIN_CHAT_ID=5391760292
# Token del túnel de Cloudflare (cloudflared) para recibir webhooks entrantes desde Telegram en el puerto del CRM.
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoiNDM1...

# ------------------------------------------------------------------------------
# 5. INTELIGENCIA ARTIFICIAL — MODELOS CHAT PRINCIPALES
# ------------------------------------------------------------------------------
PROVIDER_API_TOKEN=sk-...
PROVIDER_BASE_URL=https://api.deepseek.com
PROVIDER_MODEL=deepseek/deepseek-v4-flash
PROVIDER_JUDGE_MODEL=groq/llama-3.3-70b-versatile
PROVIDER_JUDGE_FALLBACK_MODEL=groq/llama-3.1-8b-instant

# Opciones de DeepSeek
MODEL_NAME=deepseek/deepseek-v4-flash
MODEL_DISPLAY=deepseek-v4-flash
DEEPSEEK_API_KEY=
DEEPSEEK_THINKING=disabled

# ------------------------------------------------------------------------------
# 6. MODELOS DE RESPALDO PARA CHAT (Fallbacks)
# ------------------------------------------------------------------------------
FALLBACK_MODEL_1=groq/llama-3.1-8b-instant
FALLBACK_MODEL_2=openrouter/free

# ------------------------------------------------------------------------------
# 7. INTELIGENCIA ARTIFICIAL — EMBEDDINGS DE TEXTO (RAG & pgvector)
# ------------------------------------------------------------------------------
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_FALLBACK_PROVIDER=nvidia
EMBEDDING_FALLBACK_MODEL=nvidia/nv-embedqa-e5-v5

# ------------------------------------------------------------------------------
# 8. MULTI-API KEYS DE PROVEEDORES
# ------------------------------------------------------------------------------
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# ------------------------------------------------------------------------------
# 9. CONFIGURACIÓN DEL AGENTE
# ------------------------------------------------------------------------------
AGENT_COALESCE_MS=4000
